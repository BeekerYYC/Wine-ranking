generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Wine {
  id            Int      @id @default(autoincrement())
  name          String
  winery        String?
  vintage       Int?
  varietal      String?
  region        String?
  country       String?
  category      String   @default("wine") // wine, coffee, beer
  color         String?  // wine: red/white/rosé/sparkling/dessert/orange, coffee: light/medium/dark, beer: ipa/lager/stout etc
  price         Float?
  rating        Int?     // 1-5
  notes         String?
  description   String?  // LLM-generated description/info
  imageData     String?  // base64 encoded image
  quantity      Int      @default(1)
  status        String   @default("collection") // collection, wishlist, consumed, restaurant
  occasion      String?  // comma-separated: date-night, party, gift, weeknight, celebration
  foodPairings  String?  // AI-generated food pairings
  onlineRating  Float?   // estimated critic/community score (out of 100)
  confidence    Float?   // AI identification confidence 0-1
  storeId       Int?
  store         Store?   @relation(fields: [storeId], references: [id])
  listId        Int?
  list          WineList? @relation(fields: [listId], references: [id])
  consumedAt    DateTime? // when marked consumed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ScanBatch {
  id          Int         @id @default(autoincrement())
  category    String      @default("wine") // wine, coffee, beer
  status      String      @default("processing") // processing, reviewing, completed
  totalPhotos Int         @default(0)
  processed   Int         @default(0)
  items       ScanItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ScanItem {
  id           Int        @id @default(autoincrement())
  batchId      Int
  batch        ScanBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  imageData    String?
  sourceIndex  Int        @default(0) // which photo in the batch this came from
  status       String     @default("pending") // pending, analyzed, confirmed, rejected
  name         String?
  winery       String?
  vintage      Int?
  varietal     String?
  region       String?
  country      String?
  color        String?
  description  String?
  foodPairings String?
  onlineRating Float?
  confidence   Float?
  quantity     Int        @default(1) // how many of this item detected
  wineId       Int?       // set when confirmed and saved as Wine
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  wines     Wine[]
  createdAt DateTime @default(now())
}

model WineList {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  wines     Wine[]
  createdAt DateTime @default(now())
}

model Achievement {
  id          Int      @id @default(autoincrement())
  key         String   @unique // e.g. "first_wine", "five_countries"
  name        String
  description String
  icon        String   // emoji
  unlockedAt  DateTime @default(now())
}
